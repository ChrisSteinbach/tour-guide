{
  "name": "tour-guide",
  "version": "1.0.0",
  "type": "module",
  "description": "Wikipedia-powered tour guide using spherical nearest-neighbor search",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run lint && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pipeline": "tsx src/pipeline/build.ts",
    "extract": "tsx --max-old-space-size=6144 src/pipeline/extract-dump.ts",
    "lint": "tsc --noEmit && eslint src/ && stylelint \"src/**/*.css\" && prettier --check .",
    "lint:fix": "eslint src/ --fix && stylelint \"src/**/*.css\" --fix && prettier --write .",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "lint:eslint": "eslint src/",
    "lint:eslint:fix": "eslint src/ --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChrisSteinbach/tour-guide.git"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4"
  }
}
